{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ImgViewer",
  "version": "0.1.0",
  "identifier": "com.meandmybadself.imgviewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Img Viewer",
        "width": 1280,
        "height": 820,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**", "/**", "$HOME/**", "/Volumes/**", "/private/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
